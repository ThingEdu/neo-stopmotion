# Copy this file to scripts/.env.publish and fill in your tokens.
# NEVER commit the real .env.publish file — it is gitignored.

# Username is always the literal string __token__ when using API tokens.
TWINE_USERNAME=__token__

# Real PyPI token — generate at https://pypi.org/manage/account/token/
TWINE_PASSWORD=pypi-XXXXXXXX

# TestPyPI token — generate at https://test.pypi.org/manage/account/token/
# Optional: if unset, TWINE_PASSWORD is used for TestPyPI uploads as well.
TWINE_TEST_PASSWORD=pypi-XXXXXXXX
